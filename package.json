{
  "name": "script-stage",
  "version": "0.3.2",
  "description": "Write the Script, We'll Play the Show",
  "scripts": {
    "stage": "tsx scripts/md-ts-director.ts",
    "dress": "tsx scripts/dress-rehearsal.ts",
    "play": "npm run dress && tsx scripts/play.ts",
    "show": "npm run dress && playwright test --ui",
    "review": "npx monocart show-report test-results/monocart-report/index.html",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write . --log-level silent",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "keywords": [
    "playwright",
    "testing",
    "markdown",
    "test-cases",
    "automation",
    "manual-testing",
    "cyborg-testing"
  ],
  "author": "Andrii Pohanovskyi <poganovsky@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnPo73/script-stage"
  },
  "homepage": "https://github.com/AnPo73/script-stage#readme",
  "bugs": {
    "url": "https://github.com/AnPo73/script-stage/issues"
  },
  "devDependencies": {
    "@cyborgtests/test": "^0.3.0",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "glob": "^13.0.6",
    "monocart-reporter": "^2.11.1",
    "prettier": "^3.8.3",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
